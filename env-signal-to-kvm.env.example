# signal-to-kvm.env — daemon configuration
# Copied to /opt/signal-to-kvm/signal-to-kvm.env on install.
# DO NOT commit this file with real secrets.

# ---------- Signal ----------
SIGNAL_API_BASE=http://127.0.0.1:8080
# Your linked Signal number (E.164 format, e.g. +33XXXXXXXXX).
# install.sh fills this in from the linked account.
SIGNAL_NUMBER=

# ---------- Bridge HTTP server ----------
BRIDGE_HOST=127.0.0.1
BRIDGE_PORT=8765

# ---------- Targets ----------
# Which targets to load. Anything not in KVM_TARGETS is ignored even if its
# *_KVM_BASE is set. Leave both targets configured even if you only use one;
# the daemon handles "target offline" gracefully.
KVM_TARGETS=mac,win
DEFAULT_TARGET=mac

# ---------- Mac KVM (target=mac) ----------
MAC_KVM_BASE=https://glkvm-mac.local
MAC_KVM_USER=admin
MAC_KVM_PASSWD=
MAC_KVM_KEYMAP=en-us
MAC_KVM_VERIFY_TLS=0

# ---------- Windows KVM (target=win) ----------
WIN_KVM_BASE=https://glkvm-win.local
WIN_KVM_USER=admin
WIN_KVM_PASSWD=
WIN_KVM_KEYMAP=en-us
WIN_KVM_VERIFY_TLS=0

# ---------- Behaviour tuning ----------
# Time after Cmd/Ctrl+G or Cmd/Ctrl+E before typing (Teams takes a moment to focus)
SEARCH_AFTER_FOCUS_MS=1000
# Time after typing a name/slash before Enter (search results need to populate)
SEARCH_AFTER_TYPE_MS=1000
# Pause after typing a message before screenshotting (UI settle)
TYPING_SETTLE_MS=300
# Hold a key for at least this between events
KEYSTROKE_DELAY_MS=60
# How long a draft waits for confirm/cancel before being discarded (seconds)
PENDING_TIMEOUT_SECONDS=180
# Userscript screenshot fulfilment timeout (seconds)
SCREENSHOT_TIMEOUT_SECONDS=8
# Refuse to type messages longer than this
MAX_MESSAGE_CHARS=1000
# Default jiggler interval when set-jiggler is enabled without an explicit value
JIGGLER_DEFAULT_INTERVAL=240

# Logging level: DEBUG, INFO, WARNING, ERROR
LOGLEVEL=INFO
